# ── 데이터베이스 (Postgres) ───────────────────────────────
# Neon / Supabase / Vercel Postgres 등에서 발급한 연결 문자열
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# ── 한국은행 ECOS OpenAPI ─────────────────────────────────
# https://ecos.bok.or.kr/api/  → 회원가입 후 인증키 발급(무료)
ECOS_API_KEY=YOUR_ECOS_KEY

# ── FRED (St. Louis Fed) ──────────────────────────────────
# https://fred.stlouisfed.org/docs/api/api_key.html (무료)
FRED_API_KEY=YOUR_FRED_KEY

# ── Cron 보호용 시크릿 ────────────────────────────────────
# 임의의 긴 문자열. Vercel Cron은 이 값을 Authorization 헤더로 전달하도록 설정.
CRON_SECRET=change-me-to-a-long-random-string

# ── 배포 주소(카톡 메시지 링크/리다이렉트용) ──────────────
APP_BASE_URL=https://macro-monitor-sigma.vercel.app

# ── 카카오 '나에게 보내기' (아침 자동발송) ─────────────────
# 카카오 개발자(https://developers.kakao.com) 앱 REST API 키
KAKAO_REST_API_KEY=
# (선택) 보안 강화: 카카오 로그인 'Client Secret' 사용 시
KAKAO_CLIENT_SECRET=
# 리프레시 토큰은 최초 /api/kakao/login 1회 인증 후 DB(app_config)에 자동 저장됨.
# (초기 시드가 필요하면 아래에 직접 넣어도 됨)
KAKAO_REFRESH_TOKEN=
